# MyBudget — Apps Script integration
# Copy this file to .env.local and fill in your values.
# These are optional: the same values can be set in the app's Settings screen.

# The deployed web app URL from Extensions → Apps Script → Deploy → Web app
VITE_APPS_SCRIPT_URL=

# The secret token you set in apps-script/Code.gs (SECRET_TOKEN)
VITE_APPS_SCRIPT_SECRET=
